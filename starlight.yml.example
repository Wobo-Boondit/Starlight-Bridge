# Starlight Bridge Configuration
# Docs: https://github.com/AidanTheBandit/Starlight-Bridge

server:
  host: "127.0.0.1"       # loopback by default — change to 0.0.0.0 only if you need external access
  port: 7878
  tls:
    enabled: false
    # cert: "/path/to/cert.pem"
    # key: "/path/to/key.pem"

# Authentication tokens for apps connecting to the bridge
# Generate a random token: openssl rand -hex 32
tokens:
  - token: "REPLACE_WITH_RANDOM_TOKEN"
    name: "My App"
    allowed_models:
      - "*"              # allow all models, or use globs like "hermes-*"

# ACP-compatible agents
# The model_prefix determines routing: model "hermes-glm-5.2" → prefix "hermes"
acp_clients:
  - model_prefix: "hermes"
    command: "hermes"
    args: ["acp"]
    # env:
    #   HOME: "/home/user"
    # cwd: "/home/user"

  # - model_prefix: "claude"
  #   command: "claude"
  #   args: []

# Session management
sessions:
  persist: true
  idle_timeout: 300
  max_sessions: 10

# MCP tool registration
mcp:
  server_name: "starlight-bridge"
  cleanup_after_request: true

# Optional rapid mode: answer simple prompts with a fast OpenAI-compatible model.
# If the model calls escalate_to_agent (or fails), Starlight falls through to ACP.
# Disabled by default. Prefer STARLIGHT_RAPID_API_KEY over putting keys in this file.
# rapid:
#   enabled: true
#   base_url: "https://generativelanguage.googleapis.com/v1beta/openai"
#   api_key: ""   # or set STARLIGHT_RAPID_API_KEY
#   model: "gemini-3-flash-preview"
#   escalate_tool: "escalate_to_agent"
#   timeout_ms: 12000

# Optional rapid mode: answer simple prompts with a fast OpenAI-compatible model.
# The rapid model gets its own system_prompt teaching it to escalate anything beyond
# general Q&A / weather / vision. No product hostnames belong here.
# rapid:
#   enabled: true
#   base_url: "https://generativelanguage.googleapis.com/v1beta/openai"
#   api_key: ""   # or STARLIGHT_RAPID_API_KEY
#   model: "gemini-3-flash-preview"
#   escalate_tool: "escalate_to_agent"
#   timeout_ms: 12000
#   system_prompt: "You are RAPID..."

# Optional response shaping for clients that cannot render markdown (TTS/wearables)
# response:
#   strip_markdown: true

